<?xml version="1.0" encoding="UTF-8"?>
<metamodeloDC:DiagramaClases
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:metamodeloDC="http://www.example.org/metamodeloDC"
    xsi:schemaLocation="http://www.example.org/metamodeloDC metamodeloDC.ecore">
  <clases nombre="Vehiculo">
    <atributos
        nombre="matricula"
        tipo="String"/>
    <atributos
        nombre="marca"
        tipo="String"/>
    <atributos
        nombre="modelo"
        tipo="String"/>
  </clases>
  <clases nombre="Moto">
    <herencias
        padre="//@clases.0"/>
    <atributos
        nombre="cilindrada"
        tipo="String"/>
  </clases>
  <clases nombre="Coche">
    <herencias
        padre="//@clases.0"/>
    <atributos
        nombre="numPuertas"
        tipo="String"/>
  </clases>
  <clases nombre="CocheGasolina">
    <herencias
        padre="//@clases.2"/>
    <atributos
        nombre="capacidadDepisito"
        tipo="String"/>
  </clases>
  <clases nombre="CocheElectrico">
    <herencias
        padre="//@clases.2"/>
    <atributos
        nombre="autonomiaKm"
        tipo="String"/>
  </clases>
  <clases nombre="Persona">
    <clasesAsociacion
        nombre="Contrato"
        destino="//@clases.0"/>
    <atributos
        nombre="dni"
        tipo="String"/>
    <atributos
        nombre="nombre"
        tipo="String"/>
  </clases>
  <clases nombre="Aseguradora">
    <relaciones
        nombre="asegura"
        rolOrigen="aseguradora"
        rolDestino="vehiculos"
        cardMinOrigen="1"
        cardMaxOrigen="1"
        cardMaxDestino="-1"/>
    <atributos
        nombre="cif"
        tipo="String"/>
  </clases>
  <clases nombre="Contrato">
    <atributos
        nombre="fechaIni"
        tipo="String"/>
    <atributos
        nombre="fechaFin"
        tipo="String"/>
    <atributos
        nombre="precioTotal"
        tipo="String"/>
  </clases>
</metamodeloDC:DiagramaClases>
