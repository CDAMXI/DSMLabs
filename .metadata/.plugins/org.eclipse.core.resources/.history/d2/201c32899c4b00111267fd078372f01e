module DC2ER;
create ER : ER_2026 from DC : DC_UML;

helper def: tipoToTipoER(t : DC_UML!Tipos) : ER_2026!TiposER =
  if t = #entero   then #integer
  else if t = #cadena  then #string
  else if t = #real    then #double
  else if t = #boolean then #bool
  else #fecha
  endif endif endif endif;

helper context DC_UML!Clase def: relacionesFK : Sequence(DC_UML!Relacion) =
  DC_UML!Relacion.allInstances()
    ->select(r | r.claseasociacion.oclIsUndefined())
    ->select(r |
      r.finRelacion->exists(fr | fr.clase = self and fr.max <> 1) and
      r.finRelacion->exists(fr | fr.clase <> self and fr.max = 1)
    );

-- Lazy rule: columna PK de una Clase
unique lazy rule PKCol {
  from c : DC_UML!Clase
  to col : ER_2026!Columna (
    nombre     <- 'id_' + c.nombre,
    tipo       <- #integer,
    esPrimaria <- true,
    esUnico    <- true,
    esNulo     <- false,
    rango      <- 0
  )
}

-- Lazy rule: columna FK para una Relacion con max=1 (Inc6)
unique lazy rule FKCol {
  from r : DC_UML!Relacion
  to col : ER_2026!Columna (
    nombre     <- 'id_' + r.finRelacion->select(fr | fr.max = 1)->first().clase.nombre,
    tipo       <- #integer,
    esPrimaria <- false,
    esUnico    <- false,
    rango      <- 0,
    esNulo     <- r.finRelacion->select(fr | fr.max <> 1)->first().min = 0
  )
}

-- Lazy rule: columna FK para un FinRelacion de ClaseAsociacion (Inc7)
unique lazy rule FKColCA {
  from fr : DC_UML!FinRelacion
  to col : ER_2026!Columna (
    nombre     <- 'id_' + fr.clase.nombre,
    tipo       <- #integer,
    esPrimaria <- false,
    esUnico    <- false,
    rango      <- 0,
    esNulo     <- false
  )
}

-- Incremento 1+2+6+7: Diagrama → Esquema con Tablas y ClavesAjenas
rule Diagrama2Esquema {
  from d : DC_UML!Diagrama
  to e : ER_2026!Esquema (
    nombre       <- d.nombre,
    tablas       <- DC_UML!Clase.allInstances(),
    clavesAjenas <- d.relaciones->select(r |
      r.finRelacion->exists(fr | fr.max = 1) and
      r.claseasociacion.oclIsUndefined()
    )->union(
      DC_UML!FinRelacion.allInstances()->select(fr |
        not fr.relacion.claseasociacion.oclIsUndefined()
      )
    )
  )
}

-- Incremento 2+3+4+5+6: Clase regular → Tabla
rule Clase2Tabla {
  from c : DC_UML!Clase (c.oclIsTypeOf(DC_UML!Clase))
  to t : ER_2026!Tabla (
    nombre   <- c.nombre,
    columnas <- Sequence{thisModule.PKCol(c)}->union(
      c.atributos->union(
        c.relacionesFK->collect(r | thisModule.FKCol(r))
      )
    )
  )
}

-- Incremento 2+3+4+5+7: ClaseAsociacion → Tabla con FKs
rule ClaseAsociacion2Tabla {
  from ca : DC_UML!ClaseAsociacion
  to t : ER_2026!Tabla (
    nombre   <- ca.nombre,
    columnas <- Sequence{thisModule.PKCol(ca)}->union(
      ca.atributos->union(
        ca.asociacion.finRelacion->collect(fr | thisModule.FKColCA(fr))
      )
    )
  )
}

-- Incremento 4+5: Atributo → Columna
rule Atributo2Columna {
  from a : DC_UML!Atributo
  to col : ER_2026!Columna (
    nombre     <- a.nombre,
    tipo       <- thisModule.tipoToTipoER(a.tipo),
    esPrimaria <- false,
    esUnico    <- false,
    rango      <- a.max,
    esNulo     <- a.min = 0
  )
}

-- Incremento 6: Relacion con max=1 → ClaveAjena
rule Relacion2ClaveAjena {
  from r : DC_UML!Relacion (
    r.finRelacion->exists(fr | fr.max = 1) and
    r.claseasociacion.oclIsUndefined()
  )
  to fk : ER_2026!ClaveAjena (
    nombre        <- 'FK_' + r.nombre,
    columnas      <- Sequence{thisModule.FKCol(r)},
    referenciadas <- Sequence{thisModule.PKCol(
      r.finRelacion->select(fr | fr.max = 1)->first().clase
    )}
  )
}

-- Incremento 7: FinRelacion de ClaseAsociacion → ClaveAjena
rule FinRelacionCA2ClaveAjena {
  from fr : DC_UML!FinRelacion (
    not fr.relacion.claseasociacion.oclIsUndefined()
  )
  to fk : ER_2026!ClaveAjena (
    nombre        <- 'FK_' + fr.relacion.nombre + '_' + fr.clase.nombre,
    columnas      <- Sequence{thisModule.FKColCA(fr)},
    referenciadas <- Sequence{thisModule.PKCol(fr.clase)}
  )
}